# Required for production. Local development uses safe development-only fallbacks.
VAULT2077_DATA_KEY=replace-with-a-long-random-secret
VAULT2077_ADMIN_PASSWORD=replace-with-a-strong-shared-password
VAULT2077_ADMIN_SESSION_SECRET=replace-with-another-long-random-secret

# Optional, but strongly recommended to avoid GitHub API rate limits.
GITHUB_TOKEN=

# Content pipeline: the overseas collector signs public-only source packets;
# this domestic endpoint verifies them before any LLM processing or publishing.
VAULT2077_PIPELINE_SHARED_SECRET=replace-with-a-long-random-secret
VAULT2077_LLM_BASE_URL=
VAULT2077_LLM_API_KEY=
VAULT2077_LLM_MODEL=
