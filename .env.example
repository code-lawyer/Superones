# Required for production. Local development uses safe development-only fallbacks.
VAULT2077_DATA_KEY=replace-with-a-long-random-secret
VAULT2077_ADMIN_PASSWORD=replace-with-a-strong-shared-password
VAULT2077_ADMIN_SESSION_SECRET=replace-with-another-long-random-secret

# Domestic server. Optional, but strongly recommended for Frontier verification
# and SiC repository/README/license hydration. The Actions collector uses the
# separate VAULT2077_GITHUB_READ_TOKEN secret.
GITHUB_TOKEN=

# Hourly Frontier ranking refresh and automatic quarterly settlement.
VAULT2077_FRONTIER_TICK_SECRET=replace-with-a-long-random-secret

# Content pipeline: the overseas collector signs public-only source packets;
# this domestic endpoint verifies them before any LLM processing or publishing.
VAULT2077_PIPELINE_SHARED_SECRET=replace-with-a-long-random-secret
# Optional separate worker secret; defaults to the shared ingest secret.
VAULT2077_PIPELINE_WORKER_SECRET=
# Persistent directory on the domestic VPS; mount and back this directory up.
VAULT2077_DATA_DIR=./data
# Optional emergency override. Normally read from config/source-bundle.json.
VAULT2077_SOURCE_BUNDLE_REVISION=
VAULT2077_SOURCE_BUNDLE_FILE=config/source-bundle.json
VAULT2077_MAX_ITEMS_PER_SOURCE=20
VAULT2077_COLLECTOR_CONCURRENCY=24
VAULT2077_HORIZON_CONCURRENCY=24
VAULT2077_PER_HOST_CONCURRENCY=4
VAULT2077_SOURCE_TIMEOUT_SECONDS=20
VAULT2077_MAX_UPSTREAM_BYTES=8000000
VAULT2077_PROCESS_TIMEOUT_SECONDS=300
VAULT2077_TRIGGER_PROCESSING=true
# Collector-side domestic endpoints (configured as GitHub Actions secrets).
VAULT2077_DOMESTIC_INGEST_URL=
VAULT2077_DOMESTIC_PROCESS_URL=
# Unified all-source receiver. During migration this is separate from the
# legacy content URL and points to /api/internal/acquisition.
VAULT2077_DOMESTIC_ACQUISITION_URL=
VAULT2077_DOMESTIC_ACQUISITION_PROCESS_URL=
# Set in GitHub Actions so a missing VPS endpoint can never produce a false-green run.
VAULT2077_REQUIRE_DOMESTIC_DELIVERY=false
# SiC Bearer is configured on both the domestic server and GitHub Actions.
# The two URLs are Actions-only and must point to the domestic deployment.
# The workflow silently skips an SiC step when its URL or this secret is absent,
# so production rollout must verify that both HTTP calls actually ran.
VAULT2077_SIC_COLLECTOR_SECRET=
VAULT2077_SIC_SNAPSHOT_URL=
# SiC Skill / MCP rankings on the domestic server. Smithery is always required
# for MCP and is the Skill fallback when no Vercel OIDC is present. skills.sh
# supplies curated and cumulative totals; 24H surge is always a local snapshot
# delta. Do not create a long-lived VERCEL_OIDC_TOKEN on an ordinary VPS.
VAULT2077_SMITHERY_API_KEY=
VERCEL_OIDC_TOKEN=
# Required only for the precise GitHub 24H / 7D new-Star boards. The account
# needs permission to query the public GH Archive BigQuery dataset. GitHub
# Actions obtains this short-lived value through Google Workload Identity
# Federation; local manual runs may inject a temporary token directly.
VAULT2077_GHARCHIVE_BIGQUERY_PROJECT=
VAULT2077_GHARCHIVE_BIGQUERY_ACCESS_TOKEN=
VAULT2077_SIC_CONTENT_URL=
# Domestic OpenAI-compatible provider shared by the Vault worker and SiC latest
# item editorial. Leave blank until selected; BASE_URL normally ends in /v1.
VAULT2077_LLM_BASE_URL=
VAULT2077_LLM_API_KEY=
VAULT2077_LLM_MODEL=
VAULT2077_LLM_TIMEOUT_MS=30000
