{
  "name": "vault2077",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "docs:check": "node scripts/check-docs.mjs",
    "test": "node --test --conditions=react-server --experimental-strip-types tests/*.test.ts",
    "test:pipeline:e2e": "npm run build && node scripts/run-content-pipeline-e2e.mjs",
    "test:acquisition:e2e": "npm run build && node scripts/run-acquisition-inbox-e2e.mjs",
    "content:validate-packets": "node --experimental-strip-types scripts/validate-content-packets.ts",
    "dev:check": "node scripts/check-dev-server.mjs",
    "sources:extract": "node scripts/build-source-registry.mjs",
    "sources:classify": "node scripts/classify-source-registry.mjs",
    "sources:audit": "node scripts/audit-source-registry.mjs",
    "sources:bundle": "node scripts/build-source-bundle.mjs"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.3.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "5.9.3"
  }
}
